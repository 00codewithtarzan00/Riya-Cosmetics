{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Luxury cosmetics product in the catalogue",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "category": { "type": "string", "description": "Cosmetics category" },
        "priceInINR": { "type": "number", "description": "Actual retail price in Indian Rupees" },
        "mrp": { "type": "number", "description": "Maximum Retail Price" },
        "sp": { "type": "number", "description": "Sale Price" },
        "description": { "type": "string", "description": "Elegant product description" },
        "image": { "type": "string", "description": "Image URL of the cosmetic product" },
        "hasCustomQty": { "type": "boolean", "description": "Whether the product has a custom quantity displayed" },
        "qtyVal": { "type": "number", "description": "Value of custom quantity" },
        "qtyUnit": { "type": "string", "description": "Unit of custom quantity" },
        "inStock": { "type": "boolean", "description": "Whether the product is currently in stock or out of stock" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when product was added" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Timestamp when product was updated" }
      },
      "required": ["name", "category", "priceInINR", "mrp", "sp", "description", "image"]
    },
    "BannerConfig": {
      "title": "BannerConfig",
      "description": "Configuration schema for one home page banner slider",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["None", "Image", "Video", "Text"], "description": "Current active mode" },
        "urls": { "type": "array", "description": "List of slides (either image locations or autoplay videos)" },
        "text": { "type": "string", "description": "Banner display overlay text" },
        "textColor": { "type": "string", "description": "Banner text hex color code" },
        "textSize": { "type": "string", "enum": ["xs", "sm", "md", "lg", "xl", "2xl", "3xl"], "description": "Visual font size class" }
      },
      "required": ["type", "urls", "text", "textColor", "textSize"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Generic application setting document",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Configuration key" },
        "banner1": { "type": "object", "$ref": "BannerConfig", "description": "Banner 1 configuration details" },
        "banner2": { "type": "object", "$ref": "BannerConfig", "description": "Banner 2 configuration details" }
      },
      "required": ["banner1", "banner2"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "Item in a customer's cosmetic order",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Unique product ID" },
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Selling price of product at order time" },
        "qtyVal": { "type": "number", "description": "Value of custom quantity" },
        "qtyUnit": { "type": "string", "description": "Unit of custom quantity" },
        "orderedQty": { "type": "number", "description": "Quantity ordered by the customer" }
      },
      "required": ["productId", "name", "price", "orderedQty"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique order ID" },
        "customerName": { "type": "string", "description": "Customer's name" },
        "customerPhone": { "type": "string", "description": "Customer's phone number" },
        "customerAddress": { "type": "string", "description": "Customer's delivery address" },
        "items": { "type": "array", "description": "List of ordered cosmetic items" },
        "totalAmount": { "type": "number", "description": "Total amount of the order in INR" },
        "status": { "type": "string", "enum": ["Pending", "Processing", "Dispatched", "Delivered", "Cancelled"], "description": "Current workflow status of the order" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when order was placed" }
      },
      "required": ["customerName", "customerPhone", "customerAddress", "items", "totalAmount", "status", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Catalog of precious cosmetics and makeup items"
    },
    "/settings/{settingId}": {
      "schema": "Setting",
      "description": "Application settings and dynamic slider configuration"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders submitted from checkout"
    }
  }
}
