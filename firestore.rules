rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global default safety net - deny by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for validation
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
             data.category is string && data.category.size() > 0 && data.category.size() <= 100 &&
             data.description is string && data.description.size() <= 3000 &&
             data.image is string && data.image.size() <= 2000000 &&
             data.priceInINR is number && data.priceInINR >= 0 &&
             data.mrp is number && data.mrp >= 0 &&
             data.sp is number && data.sp >= 0 &&
             (!('createdAt' in data) || data.createdAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             (!('hasCustomQty' in data) || data.hasCustomQty is bool) &&
             (!('qtyVal' in data) || data.qtyVal == null || data.qtyVal is number) &&
             (!('qtyUnit' in data) || data.qtyUnit is string) &&
             (!('inStock' in data) || data.inStock is bool);
    }

    function isValidBanner(b) {
      return b.type is string && 
             (b.type == 'None' || b.type == 'Image' || b.type == 'Video' || b.type == 'Text') &&
             b.urls is list &&
             b.text is string &&
             b.textColor is string &&
             b.textSize is string;
    }

    function isValidSetting(data) {
      return isValidBanner(data.banner1) && isValidBanner(data.banner2);
    }

    // Products Collection Rules
    match /products/{productId} {
      allow read: if true;
      allow create, update: if isValidProduct(request.resource.data);
      allow delete: if true;
    }

    // Settings Collection Rules
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isValidSetting(request.resource.data);
    }
  }
}
